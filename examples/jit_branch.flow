contract BranchEvaluationDemo {
    state EvaluateBranch {
        on evaluate_branch_expression() {
            if ((2 + 5) > (10 - 7)) {
                60 - 18;
            } else {
                40 - 39;
            }
            transition -> Completed;
        }
    }

    state Completed {
        on on_idle_tick() {
            transition -> Completed;
        }
    }
}
